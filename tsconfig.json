{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,            /* The most important setting for stability */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["core/**/*.ts", "engine/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "core/EventBus.js",
    "core/index.js",
    "core/loaders/tokenSetLoader.js",
    "engine/testActions.js"
  ]
}