{
  "type": "module",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.0",
    "@types/ws": "^8.18.1",
    "ws": "^8.18.3"
  },
  "scripts": {
    "test:core": "node --loader ./test/ts-esm-loader.js test/testCore.js",
    "test:engine": "node --loader ./test/ts-esm-loader.js test/testEngine.js",
    "test:exporters": "node --loader ./test/ts-esm-loader.js test/testExporters.js",
    "test:token": "node --loader ./test/ts-esm-loader.js test/testTokenActions.js",
    "test:batch": "node --loader ./test/ts-esm-loader.js test/testBatchActions.js",
    "test:player-transfers": "node --loader ./test/ts-esm-loader.js test/testPlayerTransfers.js",
    "test:recorder": "node --loader ./test/ts-esm-loader.js test/testRecorder.ts",
    "test:script": "node --loader ./test/ts-esm-loader.js test/testScript.ts",
    "test:agent": "node --loader ./test/ts-esm-loader.js test/testAgent.ts",
    "test:policy": "node --loader ./test/ts-esm-loader.js test/testPolicy.ts",
    "test:source-advanced": "node --loader ./test/ts-esm-loader.js test/testSourceAdvanced.ts",
    "test:crypto": "node --loader ./test/ts-esm-loader.js test/testCrypto.ts",
    "test:random": "node --loader ./test/ts-esm-loader.js test/testRandom.ts",
    "test:plugins": "node testPlugins.js",
    "test:plugin-loader": "node --loader ./test/ts-esm-loader.js test/testPluginLoader.js",
    "test:integration": "node testIntegration.js",
    "test:sync": "node --loader ./test/ts-esm-loader.js test/testSync.ts",
    "test:rule-sync": "node --loader ./test/ts-esm-loader.js test/testRuleSync.ts",
    "test:unit": "npm run test:core && npm run test:engine && npm run test:exporters && npm run test:token && npm run test:batch && npm run test:player-transfers",
    "test:engine-components": "npm run test:recorder && npm run test:script && npm run test:agent && npm run test:policy",
    "test:core-components": "npm run test:crypto && npm run test:random",
    "test:plugins-all": "npm run test:plugins && npm run test:plugin-loader",
    "test:network": "npm run test:sync && npm run test:rule-sync",
    "test": "npm run test:unit && npm run test:engine-components && npm run test:core-components && npm run test:plugins-all && npm run test:integration && npm run test:network",
    "test:pd": "node examples/prisoners-dilemma/testPD.js",
    "benchmark": "node --loader ./test/ts-esm-loader.js test/benchmarks.ts",
    "benchmark:memory": "node --expose-gc --loader ./test/ts-esm-loader.js test/benchmarks-memory.ts",
    "benchmark:all": "npm run benchmark && npm run benchmark:memory"
  }
}